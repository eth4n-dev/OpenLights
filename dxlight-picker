#!/usr/bin/env python3
import colorsys
import tkinter as tk
from pathlib import Path

VENDOR_ID = "1a86"
PRODUCT_ID = "fe07"
SEQ = 0x50

SV_SIZE = 256
HUE_W = 256
HUE_H = 20

BG = "#141414"
PANEL = "#1e1e1e"
ENTRY_BG = "#262626"
FG = "#f2f2f2"
MUTED = "#a8a8a8"


def find_device() -> str:
    hidraw_root = Path("/sys/class/hidraw")
    for node in sorted(hidraw_root.glob("hidraw*")):
        uevent = node / "device" / "uevent"
        if not uevent.exists():
            continue
        text = uevent.read_text(errors="ignore")
        if f"HID_ID=0003:{VENDOR_ID.upper()}:{PRODUCT_ID.upper()}" in text:
            return f"/dev/{node.name}"
    raise RuntimeError("No matching DX Light hidraw device found")


def make_packet(r: int, g: int, b: int, seq: int) -> bytes:
    packet = [0x52, 0x42, 0x10, seq, 0x86, 0x01, r, g, b, 0x3F, 0x40, 0x00, 0x00, 0x00, 0xFE]
    checksum = sum(packet) & 0xFF
    packet.append(checksum)
    packet += [0x00] * 48
    return bytes(packet)


def send_color(r: int, g: int, b: int):
    global SEQ
    packet = make_packet(r, g, b, SEQ)
    dev = find_device()
    with open(dev, "wb") as f:
        f.write(packet)
    SEQ = (SEQ + 1) & 0xFF
    if SEQ < 0x10:
        SEQ = 0x50


def clamp(v, lo=0, hi=255):
    return max(lo, min(hi, int(v)))


class DXLightPicker:
    def __init__(self, root: tk.Tk):
        self.root = root
        self.root.title("DX Light Picker")
        self.root.configure(bg=BG)
        self.root.resizable(False, False)

        self.h = 0.0
        self.s = 1.0
        self.v = 1.0

        self.r_var = tk.StringVar(value="255")
        self.g_var = tk.StringVar(value="0")
        self.b_var = tk.StringVar(value="0")
        self.hex_var = tk.StringVar(value="#FF0000")
        self.status_var = tk.StringVar(value="Ready")

        self.ignore_entry_updates = False
        self.pending_send = None
        self.hue_img = None
        self.sv_img = None
        self.sv_marker = None
        self.hue_marker = None

        self.build_ui()
        self.render_hue_bar()
        self.render_sv_square()
        self.update_ui_from_hsv(send=False)

    def build_ui(self):
        outer = tk.Frame(self.root, bg=BG, padx=14, pady=14)
        outer.pack()

        left = tk.Frame(outer, bg=PANEL, padx=12, pady=12)
        left.grid(row=0, column=0, sticky="n")

        right = tk.Frame(outer, bg=PANEL, padx=12, pady=12)
        right.grid(row=0, column=1, sticky="n", padx=(12, 0))

        tk.Label(left, text="DX Light", bg=PANEL, fg=FG, font=("Sans", 14, "bold")).pack(anchor="w", pady=(0, 10))

        self.sv_canvas = tk.Canvas(left, width=SV_SIZE, height=SV_SIZE, bg="black", highlightthickness=1, highlightbackground="#3a3a3a")
        self.sv_canvas.pack()
        self.sv_canvas.bind("<Button-1>", self.on_sv_pick)
        self.sv_canvas.bind("<B1-Motion>", self.on_sv_pick)

        self.hue_canvas = tk.Canvas(left, width=HUE_W, height=HUE_H, bg="black", highlightthickness=1, highlightbackground="#3a3a3a")
        self.hue_canvas.pack(pady=(10, 0))
        self.hue_canvas.bind("<Button-1>", self.on_hue_pick)
        self.hue_canvas.bind("<B1-Motion>", self.on_hue_pick)

        tk.Label(right, text="Preview", bg=PANEL, fg=MUTED, font=("Sans", 10)).pack(anchor="w")
        self.preview = tk.Frame(right, bg="#ff0000", width=150, height=72, highlightthickness=1, highlightbackground="#3a3a3a")
        self.preview.pack(fill="x", pady=(6, 8))
        self.preview.pack_propagate(False)

        tk.Label(right, textvariable=self.hex_var, bg=PANEL, fg=FG, font=("Sans", 14, "bold")).pack(anchor="w", pady=(0, 4))
        tk.Label(right, textvariable=self.status_var, bg=PANEL, fg=MUTED, font=("Sans", 9)).pack(anchor="w", pady=(0, 12))

        rgb_wrap = tk.Frame(right, bg=PANEL)
        rgb_wrap.pack(fill="x")
        self.make_rgb_row(rgb_wrap, "R", self.r_var, 0)
        self.make_rgb_row(rgb_wrap, "G", self.g_var, 1)
        self.make_rgb_row(rgb_wrap, "B", self.b_var, 2)

        btns = tk.Frame(right, bg=PANEL)
        btns.pack(fill="x", pady=(14, 0))
        self.make_button(btns, "Apply", self.apply_entries).grid(row=0, column=0, sticky="ew")
        self.make_button(btns, "Off", lambda: self.set_rgb(0, 0, 0, send=True)).grid(row=0, column=1, sticky="ew", padx=8)
        self.make_button(btns, "Quit", self.root.destroy).grid(row=0, column=2, sticky="ew")
        btns.grid_columnconfigure(0, weight=1)
        btns.grid_columnconfigure(1, weight=1)
        btns.grid_columnconfigure(2, weight=1)

        tk.Label(right, text="Drag in the square for saturation/brightness.\nDrag the lower bar for hue.\nOr type RGB values below.", bg=PANEL, fg=MUTED, justify="left", font=("Sans", 9)).pack(anchor="w", pady=(12, 0))
        for var in (self.r_var, self.g_var, self.b_var):
            var.trace_add("write", self.on_rgb_entry_change)

    def make_rgb_row(self, parent, label, var, row):
        tk.Label(parent, text=label, bg=PANEL, fg=FG, width=2, anchor="w").grid(row=row, column=0, sticky="w", pady=4)
        entry = tk.Entry(parent, textvariable=var, width=8, bg=ENTRY_BG, fg=FG, insertbackground=FG, relief="flat", highlightthickness=1, highlightbackground="#3a3a3a")
        entry.grid(row=row, column=1, sticky="ew", pady=4, padx=(6, 0))
        parent.grid_columnconfigure(1, weight=1)

    def make_button(self, parent, text, cmd):
        return tk.Button(parent, text=text, command=cmd, bg=ENTRY_BG, fg=FG, activebackground="#2d2d2d", activeforeground=FG, relief="flat", padx=12, pady=8, highlightthickness=0, bd=0)

    def render_hue_bar(self):
        row = []
        for x in range(HUE_W):
            h = x / max(1, HUE_W - 1)
            r, g, b = colorsys.hsv_to_rgb(h, 1.0, 1.0)
            row.append(f"#{int(r*255):02x}{int(g*255):02x}{int(b*255):02x}")
        data = "{" + " ".join(row) + "}"
        full = " ".join([data] * HUE_H)
        self.hue_img = tk.PhotoImage(width=HUE_W, height=HUE_H)
        self.hue_img.put(full)
        self.hue_canvas.create_image(0, 0, image=self.hue_img, anchor="nw")
        if self.hue_marker is None:
            self.hue_marker = self.hue_canvas.create_oval(0, 2, 12, HUE_H - 2, outline="white", width=2)
        self.update_hue_marker()

    def render_sv_square(self):
        base_r, base_g, base_b = colorsys.hsv_to_rgb(self.h, 1.0, 1.0)
        rows = []
        for y in range(SV_SIZE):
            v = 1.0 - (y / max(1, SV_SIZE - 1))
            pixels = []
            for x in range(SV_SIZE):
                s = x / max(1, SV_SIZE - 1)
                r = int(round(((1 - s) + s * base_r) * v * 255))
                g = int(round(((1 - s) + s * base_g) * v * 255))
                b = int(round(((1 - s) + s * base_b) * v * 255))
                pixels.append(f"#{r:02x}{g:02x}{b:02x}")
            rows.append("{" + " ".join(pixels) + "}")
        self.sv_img = tk.PhotoImage(width=SV_SIZE, height=SV_SIZE)
        self.sv_img.put(" ".join(rows))
        self.sv_canvas.delete("all")
        self.sv_canvas.create_image(0, 0, image=self.sv_img, anchor="nw")
        self.sv_marker = self.sv_canvas.create_oval(0, 0, 0, 0, outline="white", width=2)
        self.update_sv_marker()

    def update_sv_marker(self):
        x = int(round(self.s * (SV_SIZE - 1)))
        y = int(round((1.0 - self.v) * (SV_SIZE - 1)))
        self.sv_canvas.coords(self.sv_marker, x - 6, y - 6, x + 6, y + 6)

    def update_hue_marker(self):
        x = int(round(self.h * (HUE_W - 1)))
        self.hue_canvas.coords(self.hue_marker, x - 6, 2, x + 6, HUE_H - 2)

    def on_hue_pick(self, event):
        x = max(0, min(HUE_W - 1, event.x))
        self.h = x / max(1, HUE_W - 1)
        self.update_hue_marker()
        self.render_sv_square()
        self.update_ui_from_hsv(send=True)

    def on_sv_pick(self, event):
        x = max(0, min(SV_SIZE - 1, event.x))
        y = max(0, min(SV_SIZE - 1, event.y))
        self.s = x / max(1, SV_SIZE - 1)
        self.v = 1.0 - (y / max(1, SV_SIZE - 1))
        self.update_sv_marker()
        self.update_ui_from_hsv(send=True)

    def on_rgb_entry_change(self, *_):
        if self.ignore_entry_updates:
            return
        if self.pending_send is not None:
            self.root.after_cancel(self.pending_send)
        self.pending_send = self.root.after(120, self.apply_entries)

    def set_rgb(self, r, g, b, send=True):
        self.ignore_entry_updates = True
        self.r_var.set(str(clamp(r)))
        self.g_var.set(str(clamp(g)))
        self.b_var.set(str(clamp(b)))
        self.ignore_entry_updates = False
        self.apply_entries(send=send)

    def apply_entries(self, send=True):
        self.pending_send = None
        try:
            r = clamp(self.r_var.get()); g = clamp(self.g_var.get()); b = clamp(self.b_var.get())
        except ValueError:
            self.status_var.set("Invalid RGB value"); return
        self.ignore_entry_updates = True
        self.r_var.set(str(r)); self.g_var.set(str(g)); self.b_var.set(str(b))
        self.ignore_entry_updates = False
        self.h, self.s, self.v = colorsys.rgb_to_hsv(r / 255, g / 255, b / 255)
        self.update_preview(r, g, b)
        self.update_hue_marker()
        self.render_sv_square()
        if send: self.try_send(r, g, b)

    def update_ui_from_hsv(self, send=True):
        r, g, b = colorsys.hsv_to_rgb(self.h, self.s, self.v)
        r = int(round(r * 255)); g = int(round(g * 255)); b = int(round(b * 255))
        self.ignore_entry_updates = True
        self.r_var.set(str(r)); self.g_var.set(str(g)); self.b_var.set(str(b))
        self.ignore_entry_updates = False
        self.update_preview(r, g, b)
        if send: self.try_send(r, g, b)

    def update_preview(self, r, g, b):
        color = f"#{r:02x}{g:02x}{b:02x}"
        self.preview.configure(bg=color)
        self.hex_var.set(color.upper())

    def try_send(self, r, g, b):
        try:
            send_color(r, g, b); self.status_var.set(f"Sent {r}, {g}, {b}")
        except PermissionError:
            self.status_var.set("Permission denied")
        except OSError as e:
            self.status_var.set(f"Device error: {e}")


def main():
    root = tk.Tk()
    DXLightPicker(root)
    root.mainloop()


if __name__ == "__main__":
    main()
