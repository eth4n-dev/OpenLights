#!/usr/bin/env python3
import sys
from pathlib import Path

VENDOR_ID = "1a86"
PRODUCT_ID = "fe07"


def find_device() -> str:
    hidraw_root = Path("/sys/class/hidraw")
    for node in sorted(hidraw_root.glob("hidraw*")):
        uevent = node / "device" / "uevent"
        if not uevent.exists():
            continue
        text = uevent.read_text(errors="ignore")
        if f"HID_ID=0003:{VENDOR_ID.upper()}:{PRODUCT_ID.upper()}" in text:
            return f"/dev/{node.name}"
    raise RuntimeError("No matching DX Light hidraw device found")


def make_packet(r: int, g: int, b: int, seq: int) -> bytes:
    packet = [
        0x52, 0x42, 0x10, seq,
        0x86, 0x01,
        r, g, b,
        0x3F, 0x40,
        0x00, 0x00, 0x00,
        0xFE,
    ]
    checksum = sum(packet) & 0xFF
    packet.append(checksum)
    packet += [0x00] * 48
    return bytes(packet)


def main():
    if len(sys.argv) not in (4, 5):
        print("Usage: dxlight R G B [seq]")
        raise SystemExit(1)

    r = int(sys.argv[1])
    g = int(sys.argv[2])
    b = int(sys.argv[3])

    if not all(0 <= x <= 255 for x in (r, g, b)):
        print("R, G, B must be between 0 and 255")
        raise SystemExit(1)

    seq = int(sys.argv[4], 0) if len(sys.argv) == 5 else 0x50
    packet = make_packet(r, g, b, seq)
    dev = find_device()

    with open(dev, "wb") as f:
        f.write(packet)

    print(f"Sent {r},{g},{b} to {dev} with seq=0x{seq:02X}")


if __name__ == "__main__":
    main()
